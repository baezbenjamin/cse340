<!-- Content Heading -->
<% if (title) { %>
<h1> <%= title %> </h1>
<% } else {
    res.redirect('/')
} %>

<!-- Message Block -->
<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
 <% errors.array().forEach(error=> { %>
   <li><%= error.msg %></li>
<% }) %>
  </ul>
<% } %>

<!-- Content -->
 <h2>You're logged in.</h2>