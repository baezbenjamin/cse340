<!-- Content Heading -->
<% if (title) { %>
<h1> <%= title %> </h1>
<% } else {
    res.redirect('/')
} %>

<!-- Message Block -->
<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
 <% errors.array().forEach(error=> { %>
   <li><%= error.msg %></li>
<% }) %>
  </ul>
<% } %>

<!-- Content -->
<div class="management-account">
  <h2>Welcome <%= userfirstname %></h2>
  <p>You're logged in.</p>
  <a href="/account/update/<%= locals.accountData.account_id %>">Edit Account Information</a>
  <% if (permissionCheck) { %>
    <h3>Inventory Management</h3>
    <a href="/inv/">Manage Inventory</a>
    <h3>Announcement Management</h3>
    <a href="/announcement/">Manage Announcements</a>
  <% } %>
</div>
